<?php

declare(strict_types=1);

if (session_status() === PHP_SESSION_NONE) {
    session_start();
}

defined('DB_HOST') || define('DB_HOST', '127.0.0.1');
defined('DB_PORT') || define('DB_PORT', '3306');
defined('DB_NAME') || define('DB_NAME', 'trbl_tours_db');
defined('DB_USER') || define('DB_USER', 'root');
defined('DB_PASS') || define('DB_PASS', '');

if (! function_exists('getDB')) {
    function getDB(): PDO
    {
        static $connection = null;

        if ($connection instanceof PDO) {
            return $connection;
        }

        $dsn = sprintf(
            'mysql:host=%s;port=%s;dbname=%s;charset=utf8mb4',
            DB_HOST,
            DB_PORT,
            DB_NAME
        );

        try {
            $connection = new PDO($dsn, DB_USER, DB_PASS, [
                PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
                PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
                PDO::ATTR_EMULATE_PREPARES => false,
            ]);

            return $connection;
        } catch (PDOException $exception) {
            throw new RuntimeException('Database connection failed: '.$exception->getMessage(), 0, $exception);
        }
    }
}

$errors = [];
$successMessage = '';

$allowedRoles = ['tourist', 'tour_guide'];
$allowedLanguages = [
    'English',
    'Tagalog',
    'Cebuano',
    'Ilocano',
    'Hiligaynon',
    'Waray',
    'Bicolano',
    'Kapampangan',
    'Pangasinan',
];

$requestedRole = isset($_GET['role']) && in_array((string) $_GET['role'], $allowedRoles, true)
    ? (string) $_GET['role']
    : 'tourist';

$formData = [
    'account_type' => $requestedRole,
    'full_name' => '',
    'email' => '',
    'phone_number' => '',
    'nationality' => '',
    'preferred_language' => 'English',
    'years_of_experience' => '',
    'license_number' => '',
    'bio' => '',
];

$requestMethod = $_SERVER['REQUEST_METHOD'] ?? 'GET';

if ($requestMethod === 'POST') {
    $formData['account_type'] = in_array($_POST['account_type'] ?? 'tourist', $allowedRoles, true)
        ? (string) $_POST['account_type']
        : 'tourist';

    $formData['full_name'] = trim((string) ($_POST['full_name'] ?? ''));
    $formData['email'] = trim((string) ($_POST['email'] ?? ''));
    $password = (string) ($_POST['password'] ?? '');
    $passwordConfirmation = (string) ($_POST['password_confirmation'] ?? '');

    if ($formData['full_name'] === '') {
        $errors[] = 'Full Name is required.';
    }

    if ($formData['email'] === '' || filter_var($formData['email'], FILTER_VALIDATE_EMAIL) === false) {
        $errors[] = 'A valid Email is required.';
    }

    if ($password === '') {
        $errors[] = 'Password is required.';
    }

    if ($password !== $passwordConfirmation) {
        $errors[] = 'Password confirmation does not match.';
    }

    if ($formData['account_type'] === 'tourist') {
        $formData['phone_number'] = trim((string) ($_POST['phone_number'] ?? ''));
        $formData['nationality'] = trim((string) ($_POST['nationality'] ?? ''));
        $formData['preferred_language'] = trim((string) ($_POST['preferred_language'] ?? 'English'));

        if ($formData['phone_number'] === '') {
            $errors[] = 'Phone Number is required for tourists.';
        }

        if ($formData['nationality'] === '') {
            $errors[] = 'Nationality is required for tourists.';
        }

        if (! in_array($formData['preferred_language'], $allowedLanguages, true)) {
            $errors[] = 'Preferred Language is invalid.';
        }
    }

    if ($formData['account_type'] === 'tour_guide') {
        $formData['phone_number'] = trim((string) ($_POST['phone_number'] ?? ''));
        $formData['years_of_experience'] = trim((string) ($_POST['years_of_experience'] ?? ''));
        $formData['license_number'] = trim((string) ($_POST['license_number'] ?? ''));
        $formData['bio'] = trim((string) ($_POST['bio'] ?? ''));

        if ($formData['phone_number'] === '') {
            $errors[] = 'Phone Number is required for tour guides.';
        }

        if ($formData['years_of_experience'] === '' || filter_var($formData['years_of_experience'], FILTER_VALIDATE_INT) === false) {
            $errors[] = 'Years of Experience must be a valid number.';
        }

        if ($formData['license_number'] === '') {
            $errors[] = 'License Number is required for tour guides.';
        }

        if ($formData['bio'] === '') {
            $errors[] = 'Bio is required for tour guides.';
        }
    }

    if ($errors === []) {
        try {
            $db = getDB();

            $emailCheck = $db->prepare('SELECT id FROM users WHERE email = :email LIMIT 1');
            $emailCheck->execute([':email' => $formData['email']]);

            if ($emailCheck->fetch() !== false) {
                $errors[] = 'This email is already registered.';
            } else {
                $db->beginTransaction();

                $userRole = $formData['account_type'];
                $userStatus = $userRole === 'tour_guide' ? 'pending' : 'active';

                $userInsert = $db->prepare(
                    'INSERT INTO users (email, password, role, full_name, status) VALUES (:email, :password, :role, :full_name, :status)'
                );

                $userInsert->execute([
                    ':email' => $formData['email'],
                    ':password' => password_hash($password, PASSWORD_DEFAULT),
                    ':role' => $userRole,
                    ':full_name' => $formData['full_name'],
                    ':status' => $userStatus,
                ]);

                $userId = (int) $db->lastInsertId();

                if ($userRole === 'tourist') {
                    $touristInsert = $db->prepare(
                        'INSERT INTO tourists_profile (user_id, phone_number, preferred_language, nationality) VALUES (:user_id, :phone_number, :preferred_language, :nationality)'
                    );

                    $touristInsert->execute([
                        ':user_id' => $userId,
                        ':phone_number' => $formData['phone_number'],
                        ':preferred_language' => strtolower($formData['preferred_language']),
                        ':nationality' => $formData['nationality'],
                    ]);
                }

                if ($userRole === 'tour_guide') {
                    $guideInsert = $db->prepare(
                        'INSERT INTO tour_guides_profile (user_id, phone_number, years_of_experience, license_number, bio, approved_by_admin) VALUES (:user_id, :phone_number, :years_of_experience, :license_number, :bio, :approved_by_admin)'
                    );

                    $guideInsert->execute([
                        ':user_id' => $userId,
                        ':phone_number' => $formData['phone_number'],
                        ':years_of_experience' => (int) $formData['years_of_experience'],
                        ':license_number' => $formData['license_number'],
                        ':bio' => $formData['bio'],
                        ':approved_by_admin' => 0,
                    ]);
                }

                $db->commit();

                $successMessage = 'Registration successful! Tour guides need admin approval before logging in.';
                header('Refresh: 3; URL=/login');
            }
        } catch (Throwable $exception) {
            if (isset($db) && $db instanceof PDO && $db->inTransaction()) {
                $db->rollBack();
            }

            $errors[] = 'Registration failed: '.$exception->getMessage();
        }
    }
}

function selected(string $a, string $b): string
{
    return $a === $b ? 'selected' : '';
}

function oldValue(array $data, string $key): string
{
    return htmlspecialchars((string) ($data[$key] ?? ''), ENT_QUOTES, 'UTF-8');
}
