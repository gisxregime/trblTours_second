<script>
    const touristTab = document.getElementById('touristTab');
    const guideTab = document.getElementById('guideTab');
    const accountTypeInput = document.getElementById('account_type');
    const touristFields = document.getElementById('touristFields');
    const guideFields = document.getElementById('guideFields');

    const touristOnlyInputs = [
        document.getElementById('tourist_phone_number'),
        document.getElementById('nationality'),
        document.getElementById('preferred_language')
    ];

    const guideOnlyInputs = [
        document.getElementById('guide_phone_number'),
        document.getElementById('years_of_experience'),
        document.getElementById('license_number'),
        document.getElementById('bio')
    ];

    function toggleRole(role) {
        accountTypeInput.value = role;

        if (role === 'tourist') {
            touristTab.classList.add('active');
            guideTab.classList.remove('active');
            touristFields.classList.remove('hidden');
            guideFields.classList.add('hidden');

            touristOnlyInputs.forEach((input) => {
                input.disabled = false;
            });

            guideOnlyInputs.forEach((input) => {
                input.disabled = true;
            });
        } else {
            guideTab.classList.add('active');
            touristTab.classList.remove('active');
            guideFields.classList.remove('hidden');
            touristFields.classList.add('hidden');

            guideOnlyInputs.forEach((input) => {
                input.disabled = false;
            });

            touristOnlyInputs.forEach((input) => {
                input.disabled = true;
            });
        }
    }

    touristTab.addEventListener('click', () => toggleRole('tourist'));
    guideTab.addEventListener('click', () => toggleRole('tour_guide'));

    toggleRole(accountTypeInput.value === 'tour_guide' ? 'tour_guide' : 'tourist');
</script>
</body>
</html>
